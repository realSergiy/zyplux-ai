{
  "extends": "@zyplux/tsconfig/web.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@/og/*": ["./og/*"],
      "@content/*": ["./content/*"]
    },
    "types": ["bun", "react", "react-dom", "mdx"],
    "plugins": [{ "name": "@mdx-js/typescript-plugin" }]
  },
  "include": ["src", "content"],
  "references": [{ "path": "../../packages/ui/tsconfig.json" }]
}
