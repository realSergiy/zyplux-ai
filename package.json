{
  "name": "zyplux-ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@cloudflare/vite-plugin": "^1.13.10",
      "@happy-dom/global-registrator": "^20",
      "@react-three/drei": "^10.7.6",
      "@react-three/fiber": "^9.3.0",
      "@react-three/postprocessing": "^3.0.4",
      "@tailwindcss/postcss": "^4.1.14",
      "@testing-library/react": "^16",
      "@totvibe/eslint-config": "^0.1.0",
      "@types/bun": "latest",
      "@types/node": "^24.6.2",
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0",
      "@types/three": "^0.180.0",
      "@vitejs/plugin-react": "^5.0.4",
      "autoprefixer": "^10.4.21",
      "clsx": "^2.1.1",
      "eslint": "^10.4.1",
      "jiti": "^2.7.0",
      "jotai": "^2.15.0",
      "knip": "^6.15.0",
      "lucide-react": "^0.544.0",
      "motion": "^12.23.22",
      "npm-check-updates": "^22.2.1",
      "prettier": "^3.8.3",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "tailwind-merge": "^3.3.1",
      "tailwindcss": "^4.1.14",
      "three": "^0.180.0",
      "typescript": "^6.0.3",
      "vite": "^7.1.9",
      "wrangler": "^4.42.0"
    }
  },
  "scripts": {
    "dev": "bun --filter @zyplux/web dev",
    "build": "bun --filter '*' build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "knip": "knip-bun",
    "test": "bun test packages/tests",
    "upgrade": "npm-check-updates --root --workspaces --format group"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "workerd"
  ],
  "devDependencies": {
    "@totvibe/eslint-config": "catalog:",
    "@types/bun": "catalog:",
    "@zyplux/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "jiti": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
